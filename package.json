{
  "name": "markdown-magic",
  "version": "0.1.0",
  "private": true,
  "description": "Prototype: shared markdown pricing for RF gun and POS (dummy data)",
  "type": "module",
  "scripts": {
    "build": "node scripts/prepare-static-deploy.mjs",
    "scan": "node src/cli.js",
    "serve": "npx --yes serve . -p 3456",
